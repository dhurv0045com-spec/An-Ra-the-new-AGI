# ================================================================================
# .env.example — Environment variable template
# Copy to .env and fill in your values:  cp .env.example .env
# ================================================================================

# ── Weights & Biases (optional) ─────────────────────────────────────────────
WANDB_API_KEY=your_wandb_api_key_here
WANDB_PROJECT=lm-scratch
WANDB_ENTITY=your_username_or_team

# ── Data paths (override config files) ──────────────────────────────────────
TRAIN_DATA=data/train.txt
VAL_DATA=data/val.txt
TEST_DATA=data/test.txt

# ── Output paths ─────────────────────────────────────────────────────────────
OUTPUT_DIR=output
CHECKPOINT_DIR=output/checkpoints
LOG_DIR=output/logs

# ── Hardware ──────────────────────────────────────────────────────────────────
CUDA_VISIBLE_DEVICES=0     # GPU index to use (0 = first GPU)
OMP_NUM_THREADS=4           # CPU threads for NumPy

# ── Python ────────────────────────────────────────────────────────────────────
PYTHONUNBUFFERED=1           # Flush stdout immediately (important for logging)
PYTHONDONTWRITEBYTECODE=1    # Don't create .pyc files
